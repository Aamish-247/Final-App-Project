<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- Map -->
    <org.osmdroid.views.MapView
        android:id="@+id/map_parent_live_tracking"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 🔝 Top Header (Rounded + Shadow) -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="40dp"
        app:cardCornerRadius="18dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#CCFFFFFF">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Live Bus Tracking"
            android:textSize="20sp"
            android:gravity="center"
            android:textStyle="bold"
            android:textColor="#333333"
            android:padding="16dp"/>
    </com.google.android.material.card.MaterialCardView>

    <!-- 📍 Recenter Button -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_recenter_map"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@id/bottom_info_card"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:src="@android:drawable/ic_menu_mylocation"
        app:backgroundTint="#FFFFFF"
        app:tint="#1976D2"
        app:fabSize="mini"
        app:elevation="6dp"/>

    <!-- 🔽 Bottom Info Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottom_info_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_margin="16dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="10dp"
        app:cardBackgroundColor="@android:color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- ETA + Distance -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="16dp">

                <!-- ETA -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Estimated Arrival"
                        android:textSize="13sp"
                        android:textColor="#757575"/>

                    <TextView
                        android:id="@+id/tv_eta_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Calculating..."
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#FF9800"/>
                </LinearLayout>

                <!-- Distance -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Distance"
                        android:textSize="13sp"
                        android:textColor="#757575"/>

                    <TextView
                        android:id="@+id/tv_distance_left"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-- km"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#1976D2"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE"
                android:layout_marginBottom="16dp"/>

            <!-- Bus Name -->
            <TextView
                android:id="@+id/tv_live_bus_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bus: Loading..."
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="4dp"/>

            <!-- Status -->
            <TextView
                android:id="@+id/tv_live_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Status: On the way to your stop"
                android:textSize="14sp"
                android:textColor="#4CAF50"
                android:textStyle="bold"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</RelativeLayout>